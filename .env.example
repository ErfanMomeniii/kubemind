# KubeMind environment configuration
# Copy to .env and fill in real values. Never commit .env.

# --- App ---
APP_ENV=development
APP_LOG_LEVEL=INFO
APP_SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32

# --- Database ---
DATABASE_URL=postgresql+asyncpg://kubemind:kubemind_dev@localhost:5432/kubemind

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- Auth ---
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# --- AI ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
AI_DEFAULT_MODEL=claude-sonnet-4-6
AI_FALLBACK_MODEL=claude-haiku-4-5-20251001
AI_MAX_TOKENS_PER_QUERY=10000
AI_DAILY_TOKEN_BUDGET_PER_USER=1000000

# --- Observability ---
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=kubemind-backend
PROMETHEUS_METRICS_PATH=/metrics

# --- Integrations (defaults; per-cluster overrides in DB) ---
KUBERNETES_KUBECONFIG=
PROMETHEUS_URL=
ARGOCD_URL=
ARGOCD_TOKEN=
GRAFANA_URL=
GRAFANA_TOKEN=
